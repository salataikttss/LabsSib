using System;

namespace ConsoleApp1
{
    class Human
    {
        public string Name { get; set; }
        public int Age { get; set; }

        public Human() { Name = "?"; Age = 0; }
        public Human(string name) { Name = name; Age = 0; }
        public Human(string name, int age) { Name = name; Age = age; }

        public void DisplayInfo() => Console.WriteLine($"{Name}, {Age} лет");
    }

    class Box<T>
    {
        private T i;
        public void Put(T item) { i = item; Console.WriteLine($"Put: {i}"); }
        public T Get() { Console.WriteLine($"Get: {i}"); return i; }
    }

    delegate void Delegate_Hello();
    delegate int Delegate_Str(string a, string b);
    delegate void Delegate3(string s);

    class Program
    {
        static void Hello_World()
        {
            Console.WriteLine("hello world");
        }
        static void Bye_World()
        {
            Console.WriteLine("buy world!");
        }

        static int summ_string(string a, string b)
        {
            string result = a + b;
            Console.WriteLine($"{a} + {b} = {result}");
            return result.Length;
        }

        static void Main(string[] args)
        {
            Delegate_Hello del1 = Hello_World;
            del1 += Bye_World;
            del1();

            Delegate_Str summstr = summ_string;

            int length = summstr("hello", "world");
            Console.WriteLine($"Длина строки: {length}");

            Human human = new Human("Салават", 19);
            Delegate_Hello employeDel = human.DisplayInfo;
            employeDel();

            Delegate_Str lambda = (x, y) => {
                string combined = x + y;
                Console.WriteLine($"Объединенная строка: {combined}");
                return combined.Length;
            };

            int result = lambda("hello", "world");
            Console.WriteLine($"Длина строки: {result}");


            Human hum = new Human("Салават", 19);
            Box<string> box = new Box<string>();
            box.Put("data");
            box.Get();
        }
    }
}
